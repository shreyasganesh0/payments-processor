# NODE_ENV — 'production' makes config.ts REQUIRE the datastore URLs (fail-fast)
# instead of defaulting to localhost. Leave unset/development locally.
NODE_ENV=development

# API
PORT=3000
CORS_ORIGIN=http://localhost:3001

# Datastores. NOTE: the DB password appears in TWO places — inside DATABASE_URL
# AND as POSTGRES_PASSWORD (consumed by the postgres container / k8s secret).
# They must match; rotating the password means changing both.
DATABASE_URL=postgres://payments:payments@localhost:5432/payments
POSTGRES_PASSWORD=payments
REDIS_URL=redis://localhost:6379
# NOTE: in compose/k8s these two use the service hostnames (postgres/valkey),
# not localhost — they are legitimately per-environment, so each mode sets its own.

# Worker
METRICS_PORT=9101

# ── Behavioral tuning (all optional; config.ts holds the defaults shown). ──
# Uncomment to override a default in any environment.
# WORKER_BASE_BACKOFF_MS=1000     # retry backoff base (also drives webhook retries)
# WORKER_CAP_BACKOFF_MS=30000
# WORKER_MAX_RETRIES=5
# BANK_ADAPTER=simulated          # which bank implementation (see bank.module.ts)
# BANK_TIMEOUT_MS=2000
# BANK_BREAKER_THRESHOLD=5
# BANK_BREAKER_OPEN_MS=10000
# BANK_SYNC_MS=2000               # chaos-config poll interval (worker); e2e reads this too
# RELAY_POLL_MS=5000
# REAPER_INTERVAL_MS=10000
# REAPER_DEADLINE_MS=60000
# WEBHOOK_MAX_ATTEMPTS=5
# WEBHOOK_HTTP_TIMEOUT_MS=5000
# WEBHOOK_POLL_MS=5000

# Web — build-time only. Next inlines this at `next build`, so a change needs a
# rebuild (it is NOT read at runtime).
NEXT_PUBLIC_API_BASE=http://localhost:3000

# E2E black-box suite — which running stack `make e2e` targets. Client-side
# pointer (like NEXT_PUBLIC_API_BASE), so it is not part of the server config.
# Defaults to http://localhost:$PORT; set to the ingress host for a cluster:
#   E2E_API_BASE=http://api.payments.local
E2E_API_BASE=http://localhost:3000
